{
  "name": "local-llmstxt-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n server,ui -c blue,magenta \"pnpm dev:server\" \"pnpm dev:ui\"",
    "dev:server": "tsx watch server/index.ts",
    "dev:ui": "vite",
    "build": "vite build && tsc -p tsconfig.server.json",
    "start": "node dist/server/index.js",
    "docs-import": "tsx server/bin/docs-import.ts",
    "typecheck": "tsc -p tsconfig.server.json --noEmit && tsc -p tsconfig.ui.json --noEmit"
  },
  "dependencies": {
    "@apidevtools/swagger-parser": "^12.1.0",
    "@fastify/static": "^7.0.4",
    "@mozilla/readability": "^0.5.0",
    "better-sqlite3": "^11.3.0",
    "fastify": "^4.28.1",
    "jsdom": "^25.0.1",
    "turndown": "^7.2.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/jsdom": "^21.1.7",
    "@types/node": "^22.7.4",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "@types/turndown": "^5.0.5",
    "@vitejs/plugin-react": "^4.3.2",
    "concurrently": "^9.0.1",
    "playwright": "^1.53.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.0.1",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2",
    "vite": "^5.4.8"
  },
  "packageManager": "pnpm@9.0.0"
}
